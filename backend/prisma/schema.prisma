datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum JobPosition {
  CLEANER
  SUPERVISOR
  SAFETY_OFFICER
  MANAGER
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
}

model Application {
  id              String            @id // Format: SH-EMP-YYYYMMDD-XXXXX
  fullName        String
  mobile          String            @unique
  email           String            @unique
  gender          String
  dateOfBirth     DateTime
  aadhaarEnc      String            // AES-256 encrypted Aadhaar number
  aadhaarHash     String            @unique // SHA-256 hash for fast duplicate detection
  address         String
  city            String
  state           String
  pinCode         String
  position        JobPosition
  experience      Int               // 0 to 20 years
  preferredCities String[]          // Postgres string array
  expectedSalary  Float
  photoUrl        String            // Cloudinary image URL
  aadhaarFrontUrl String            // Cloudinary image URL
  aadhaarBackUrl  String            // Cloudinary image URL
  resumeUrl       String?           // Optional Cloudinary PDF URL
  status          ApplicationStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt hashed
  name      String
  createdAt DateTime @default(now())
}

model DailyEarning {
  id            String        @id @default(cuid())
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id])
  date          DateTime      @db.Date
  jobsCompleted Int           @default(0)
  baseAmount    Decimal       @db.Decimal(10,2) @default(0)
  bonusAmount   Decimal       @db.Decimal(10,2) @default(0)
  totalAmount   Decimal       @db.Decimal(10,2)
  notes         String?
  addedBy       String        // admin id who logged it
  status        EarningStatus @default(UNPAID)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([employeeId, date])
}

model PayoutRequest {
  id            String        @id @default(cuid())
  requestId     String        @unique
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id])
  amount        Decimal       @db.Decimal(10,2)
  fromDate      DateTime      @db.Date
  toDate        DateTime      @db.Date
  method        PayoutMethod  @default(UPI)
  upiId         String?
  bankAccount   String?
  bankIfsc      String?
  status        PayoutStatus  @default(PENDING)
  adminNotes    String?
  paidAt        DateTime?
  paidVia       String?       // txn ref id
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum EarningStatus {
  UNPAID
  REQUESTED
  PAID
}

enum PayoutMethod {
  UPI
  BANK_TRANSFER
  CASH
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Employee {
  id              String          @id @default(cuid())
  applicationId   String?         @unique
  fullName        String
  mobile          String          @unique
  email           String          @unique
  city            String
  jobPosition     JobPosition
  status          String          @default("HIRED")
  employeePin     String?         // 4-digit login PIN (hashed)
  isActive        Boolean         @default(true)
  dailyEarnings   DailyEarning[]
  payoutRequests  PayoutRequest[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
